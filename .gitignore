# Root .gitignore for Ethara Nexus monorepo

# Dependencies
node_modules/
.pnp
.pnp.js

# Environment variables — NEVER commit these
.env
*.env.local
*.env.development.local
*.env.test.local
*.env.production.local

# Build outputs
dist/
build/
.next/

# Prisma
prisma/migrations/**/migration_lock.toml

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Test coverage
coverage/
