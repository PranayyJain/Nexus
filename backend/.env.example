# ====================================================
# ETHARA NEXUS - Backend Environment Variables
# Copy this to .env and fill in your values
# ====================================================

# PostgreSQL connection string (Railway or Supabase)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# JWT secret key - use a long, random string in production
JWT_SECRET="ethara-nexus-super-secret-jwt-key-change-in-production"

# JWT expiration (7 days)
JWT_EXPIRES_IN="7d"

# Server port
PORT=5000

# Frontend URL for CORS (update for production)
FRONTEND_URL="http://localhost:5173"

# Node environment
NODE_ENV="development"
